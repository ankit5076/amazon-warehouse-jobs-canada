{
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/images/amazon.png",
      "48": "assets/images/amazon.png",
      "128": "assets/images/amazon.png"
    }
  },
  "background": {
    "service_worker": "background.0f5204590eba.js"
  },
  "content_scripts": [
    {
      "js": [
        "content-application.4702cd7d86c5.js"
      ],
      "matches": [
        "https://hiring.amazon.ca/application*",
        "https://hiring.amazon.com/application*"
      ],
      "run_at": "document_start"
    },
    {
      "css": [
        "sweetalert.9ff7b8cfb478.css",
        "content.78dcd83ba5be.css"
      ],
      "js": [
        "sweetalert.f8f749179a9b.js",
        "content-main.acfde2cdfb14.js"
      ],
      "matches": [
        "https://hiring.amazon.ca/*",
        "https://hiring.amazon.com/*",
        "*://auth.hiring.amazon.com/*",
        "*://auth.hiring.amazon.ca/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "description": "Fastrack amazon jobs — automatically books Amazon warehouse shifts as soon as a matching slot opens.",
  "externally_connectable": {
    "matches": [
      "https://hiring.amazon.ca/*",
      "https://hiring.amazon.com/*",
      "*://auth.hiring.amazon.com/*",
      "*://auth.hiring.amazon.ca/*"
    ]
  },
  "host_permissions": [
    "https://hiring.amazon.ca/*",
    "https://hiring.amazon.com/*",
    "*://auth.hiring.amazon.com/*",
    "*://auth.hiring.amazon.ca/*"
  ],
  "icons": {
    "16": "assets/images/amazon.png",
    "48": "assets/images/amazon.png",
    "128": "assets/images/amazon.png"
  },
  "incognito": "spanning",
  "key": "",
  "manifest_version": 3,
  "name": "Fastrack amazon jobs",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "declarativeContent",
    "scripting"
  ],
  "update_url": "https://clients2.google.com/service/update2/crx",
  "version": "2.10.0",
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/images/amazon.png",
        "assets/images/fastrack_amazon.png",
        "assets/sounds/alert.wav",
        "assets/sounds/alert_long.wav",
        "assets/fonts/Quicksand.ttf"
      ]
    },
    {
      "matches": [
        "https://hiring.amazon.ca/*",
        "https://hiring.amazon.com/*"
      ],
      "resources": [
        "direct-waf-bridge-page.js"
      ]
    }
  ]
}
